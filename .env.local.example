# OnchainKit API Key (optional but recommended — enables Smart Wallet features)
# Get one at https://portal.cdp.coinbase.com/
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Your dev wallet private key for server-side admin operations (hex-prefixed)
# Get it with: cast wallet private-key "YOUR TWELVE WORD RECOVERY PHRASE"
PRIVATE_KEY=0x

# Base Sepolia RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
